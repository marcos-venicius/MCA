#!/usr/local/bin/mca

a = 0
b = 1
n = 0
M = 15

CONSTANT = 11.13

break_value = while {
    t = a
    a = b
    b = t + b
    n += 1

    println(n, a)

    should_be_unit = if n >= M {
        println(3030)

        break CONSTANT
    }

    if should_be_unit != ? {
      exit(123);
    }
};

if break_value == CONSTANT {
    println()
    println(1337)
};

