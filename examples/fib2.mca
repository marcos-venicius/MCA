a = 0
b = 1
n = 0
M = 15

CONSTANT = 11.13

break_value = while {
    t = a
    a = b
    b = t + b
    n = n + 1

    println(n, a)

    should_be_0 = if n >= M {
        println(3030)

        break CONSTANT
    }

    if should_be_0 != 0 {
      exit(123);
    }
};

if break_value == CONSTANT {
    println()
    println(1337)
};

