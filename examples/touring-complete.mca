#!/usr/local/bin/mca -i

target = 10.0;

a = 0.0;
b = 1.0;
counter = 1.0;

final_result = while counter < target {
    temp = a + b;
    a = b;
    b = temp;
    
    counter = counter + 1.0;
    
    b 
};

println(final_result)

if final_result == 55.0 {
  exit(0)
} else {
  exit(1)
}

