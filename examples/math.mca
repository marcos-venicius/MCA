#!/usr/local/bin/mca

# working example

const math = import('math')

x = -((((5.0! + -20) / 10) ^ 2) % 11) * 10 * -1 - 10;
y = 3 * 3 - 1;
z = 3 * (3 - 1);

println(x, y, z);

println();

result = math.abs(x + y / -z);

capture_println_last_value = println(result);

println();

println(capture_println_last_value);

