#!/usr/local/bin/mca

# You can inspect data type by using 'type(x)' function
# This function will print to default stdout the data type like 'type(value)'

type(0)
type(0.0)

a = 10
b = 10
c = PI()
d = E()

type(a / b)

X = type(a / (b + 1))

type(c)
type(d)

type(X)

type(true)

type(false)

type(1 == 1)
type(?)
type('Hello \'World\' \\\\//')

