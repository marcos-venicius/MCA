#!/usr/local/bin/mca

m = {
  '-23456': 'as_int',
  '23456': 'as_int',
  '32': 'as_float',
  '32.235': 'as_float',
  '-32.235': 'as_float',
  -32: 'as_float',
  32: 'as_float',
  1: 'as_string',
  -1: 'as_string',
}

for k, v : m {
  c = if v == 'as_int' as_int(k) elif v == 'as_float' as_float(k) elif v == 'as_string' as_string(k)

  print(v, '(', type(k), '(', k, ')) > ', type(c), '(', c, ')\n')
}

m = {}

