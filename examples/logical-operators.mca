#!/usr/local/bin/mca

A = 1 and 2
B = 10 or 0
C = 0 or 0

println(A, B, C)

n            = 0
current_year = year(0)

while n < 15 {
  text = if ((current_year % 4 == 0 and current_year % 100 != 0) or (current_year % 400 == 0)) 'is a lap year' else 'is not a lap year'

  println(current_year, text)

  current_year -= 1

  n += 1
}

